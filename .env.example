# PostgreSQL Credentials for Dataverse
DB_USERNAME=your_database_username
DB_PASSWORD=your_database_password

# PostgreSQL Connection (mapped from DB_* variables)
PG_HOST=your_postgres_host.compute-1.amazonaws.com
PG_PORT=5432
PG_DATABASE=your_database_name
PG_USER=your_database_username
PG_PASSWORD=your_database_password

# Slack API Token for Canvas Access
SLACK_TOKEN=xoxb-your-slack-bot-token-here

# AWS Credentials (if using S3)
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_REGION=us-east-1

# Salesforce Credentials (if using Salesforce loader)
# SF_USERNAME=your_salesforce_username
# SF_PASSWORD=your_salesforce_password
# SF_SECURITY_TOKEN=your_salesforce_security_token
# SF_DOMAIN=login  # or 'test' for sandbox
